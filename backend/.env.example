PORT=3000
MONGODB_URI=mongodb://localhost:27017/finance_dashboard
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development

# Email verification & password reset (generate secrets: openssl rand -base64 48)
JWT_EMAIL_VERIFY_SECRET=change_me_email_verify_secret
JWT_PASSWORD_RESET_SECRET=change_me_password_reset_secret
JWT_EMAIL_VERIFY_EXPIRES_IN=24h
JWT_PASSWORD_RESET_EXPIRES_IN=1h

# Frontend URL for links in emails
CLIENT_URL=http://localhost:5173

# SMTP (optional in dev — links are logged to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Fintrack <noreply@localhost>

# Dev: auto-verify on register & allow login without email (set false in production)
SKIP_EMAIL_VERIFY=true
